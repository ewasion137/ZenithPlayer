{
  "name": "zenith",
  "version": "2.1.0",
  "description": "A kick-ass audio player.",
  "main": "Zenith/script/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.ewasion137.zenith",
    "productName": "Zenith",
    "files": [
      "**/*",
      "!/node_modules/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^39.8.10",
    "electron-builder": "^26.0.12"
  }
}
